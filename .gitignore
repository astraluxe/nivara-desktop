# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/

# Environment files
.env
.env.local
.env*.local

# Tauri signing keys — NEVER commit private key
.tauri/*.key
!.tauri/*.key.pub

# OS
.DS_Store
Thumbs.db

